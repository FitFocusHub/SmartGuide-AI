[app]

# App info
title = SmartGuide AI
package.name = smartguide
package.domain = com.fitfocushub

# Source
source.dir = .
source.include_exts = py,png,jpg,kv,atlas,html,js,css,json

# Version
version = 1.1.0

# Requirements
requirements = python3,kivy,websocket

# Android settings
android.permissions = INTERNET
android.api = 30
android.minapi = 21
android.archs = arm64-v8a

# Build
fullscreen = 0
orientation = portrait
