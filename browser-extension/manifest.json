{
  "manifest_version": 3,
  "name": "SmartGuide AI",
  "version": "1.0.0",
  "description": "Advanced AI Navigation, Automation, Desktop and Browser Assistant",
  "author": "FitFocusHub",
  "homepage_url": "https://github.com/FitFocusHub/SmartGuide-AI",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs",
    "clipboardRead",
    "clipboardWrite"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "48": "assets/icons/icon-48.png",
      "128": "assets/icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js", "content/highlight.js", "chat/chat-ui.js"],
      "css": ["chat/chat.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "assets/icons/icon-16.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  }
}
