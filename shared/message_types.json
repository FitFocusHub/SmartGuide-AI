[
    {
        "messageType": "query",
        "description": "User sends a query from extension to desktop app",
        "fields": {
            "type": "string - 'query'",
            "query": "string - user's question",
            "context": "object - page context (url, activeElement, etc.)",
            "software": "string - software name (excel, photoshop, etc.)",
            "timestamp": "number - unix timestamp"
        }
    },
    {
        "messageType": "response",
        "description": "Desktop app sends AI response back to extension",
        "fields": {
            "type": "string - 'response'",
            "steps": "array - list of instruction steps",
            "highlight": "array - regions to highlight",
            "explanation": "string - brief explanation",
            "confidence": "number - 0.0 to 1.0"
        }
    },
    {
        "messageType": "execute",
        "description": "Extension requests desktop app to execute an action",
        "fields": {
            "type": "string - 'execute'",
            "action": "string - click|type|press|scroll|hotkey",
            "coordinates": "object - {x, y}",
            "text": "string - text to type (for type action)",
            "key": "string - key name (for press action)",
            "keys": "array - key combo (for hotkey action)"
        }
    },
    {
        "messageType": "highlight",
        "description": "Highlight regions on screen",
        "fields": {
            "type": "string - 'highlight'",
            "highlights": "array - list of {x, y, w, h, color, label}"
        }
    },
    {
        "messageType": "ping",
        "description": "Keep-alive ping",
        "fields": {
            "type": "string - 'ping'"
        }
    },
    {
        "messageType": "pong",
        "description": "Keep-alive pong response",
        "fields": {
            "type": "string - 'pong'"
        }
    }
]
